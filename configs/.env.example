# OpenClaw Gateway Configuration
# Copy this file to .env and fill in your actual values

# Gateway Authentication
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Telegram Bot (Ramiro)
OPENCLAW_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Mistral API (LLM)
OPENCLAW_MISTRAL_BASE_URL=https://api.mistral.ai/v1
OPENCLAW_MISTRAL_API_KEY=your-mistral-api-key-here

# Email (Gmail)
OPENCLAW_GMAIL_ADDRESS=your-email@gmail.com
OPENCLAW_GMAIL_APP_PASSWORD=your-gmail-app-password-here
